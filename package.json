{
  "name": "vue-ionic-budget-app",
  "version": "0.1.12",
  "author": {
    "name": "AndreiDetenkov",
    "email": "a.detenkov@gmail.com"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint --ext .ts,.vue src/ --fix",
    "sync": "ionic capacitor sync android",
    "open": "ionic capacitor open android",
    "run": "ionic capacitor run android -l --external",
    "run:android": "ionic capacitor run android --target=Pixel_7 --livereload --external",
    "release": "pnpx changelogen@latest --release --push"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/status-bar": "^8.0.2",
    "@ionic/core": "^8.8.2",
    "@ionic/vue": "^8.8.2",
    "@ionic/vue-router": "^8.8.2",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/vue-query": "^5.95.2",
    "dayjs": "^1.11.20",
    "ionicons": "^8.0.13",
    "pinia": "3.0.4",
    "vue": "3.5.24",
    "vue-router": "4.6.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^9.39.4",
    "@ionic/prettier-config": "^4.0.0",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/devtools": "^8.1.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "baseline-browser-mapping": "^2.10.11",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "7.2.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6"
  },
  "prettier": "@ionic/prettier-config",
  "engines": {
    "node": "^24",
    "pnpm": "^10"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
